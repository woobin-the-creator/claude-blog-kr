# Copy to .env and fill in. .env is gitignored (never committed).
# Create a bot with @BotFather on Telegram to get the token.
# Get your chat id by messaging the bot, then visiting:
#   https://api.telegram.org/bot<TOKEN>/getUpdates  (look for "chat":{"id":...})
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=123456789
